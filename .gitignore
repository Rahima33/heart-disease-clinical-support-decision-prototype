Thumbs.db

# Editor folders
.vscode/
.idea/

# Logs
*.log
# Frontend dependencies/build output
node_modules/
**/node_modules/
dist/
**/dist/

# Frontend local env/log output
frontend/.env
frontend/.env.*
frontend/*.log
